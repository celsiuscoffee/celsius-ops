generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── APP CONFIG ────────────────────────────────────────────
model AppConfig {
  key       String   @id
  value     Json     @default("{}")
  updatedAt DateTime @default(now()) @updatedAt
}

// ─── SHORT LINKS ───────────────────────────────────────────

model ShortLink {
  id        String   @id
  url       String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── OUTLETS ────────────────────────────────────────────────

model Outlet {
  id        String       @id @default(uuid())
  code      String       @unique
  name      String
  type      OutletType   @default(OUTLET)
  address   String
  city      String
  state     String
  phone     String?
  status    OutletStatus @default(ACTIVE)
  storehubId String?     @unique

  // Location & hours
  lat            Decimal?
  lng            Decimal?
  openTime       String?  @default("08:00")
  closeTime      String?  @default("22:00")
  daysOpen       Int[]    @default([1, 2, 3, 4, 5, 6, 7])
  isOpen         Boolean? @default(false)
  isBusy         Boolean? @default(false)
  pickupTimeMins Int?     @default(15)

  // Cross-app references
  pickupStoreId   String?  @unique  // Supabase outlet_settings.store_id (e.g. "shah-alam")
  loyaltyOutletId String?
  staffPin        String?

  // Stripe Connect
  stripeAccountId  String?
  stripeOnboarded  Boolean? @default(false)
  stripeEnabled    Boolean? @default(false)

  // Revenue Monster
  rmMerchantId   String?
  rmClientId     String?
  rmClientSecret String?
  rmPrivateKey   String?
  rmIsProduction Boolean? @default(false)
  rmEnabled      Boolean? @default(false)

  // Bukku accounting
  bukkuToken     String?
  bukkuSubdomain String?
  bukkuEnabled   Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  outletProducts    OutletProduct[]
  orders            Order[]
  invoices          Invoice[]
  stockCounts       StockCount[]
  stockBalances     StockBalance[]
  stockAdjustments  StockAdjustment[]
  receivings        Receiving[]
  parLevels         ParLevel[]
  transfersFrom     StockTransfer[] @relation("TransferFrom")
  transfersTo       StockTransfer[] @relation("TransferTo")
  storehubSyncs     StorehubSync[]
  salesTransactions SalesTransaction[]
  sopOutlets        SopOutlet[]
  checklists        Checklist[]
  sopSchedules      SopSchedule[]
  reviewSettings    ReviewSettings?
  internalFeedbacks InternalFeedback[]
  auditReports      AuditReport[]
}

enum OutletType {
  OUTLET
  CENTRAL_KITCHEN
}

enum OutletStatus {
  ACTIVE
  INACTIVE
}

// ─── USERS ──────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  name         String
  fullName     String?
  email        String?    @unique
  phone        String?    @unique
  role         UserRole
  outletId     String?
  outlet       Outlet?    @relation(fields: [outletId], references: [id])
  username     String?    @unique
  passwordHash String?
  pin          String?
  status       UserStatus @default(ACTIVE)
  outletIds    String[]   @default([])
  appAccess    String[]   @default([])
  moduleAccess Json?      @default("{}")
  permissions  String[]   @default([])
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ordersCreated    Order[]           @relation("OrderCreatedBy")
  ordersApproved   Order[]           @relation("OrderApprovedBy")
  ordersClaimed    Order[]           @relation("OrderClaimedBy")
  sopsCreated      Sop[]             @relation("SopCreatedBy")
  checklistsCompleted Checklist[]    @relation("ChecklistCompletedBy")
  checklistItems   ChecklistItem[]   @relation("ChecklistItemCompletedBy")
  sopSchedules     SopSchedule[]     @relation("ScheduleAssignedTo")
  checklistsAssigned Checklist[]     @relation("ChecklistAssignedTo")
  stockCounts      StockCount[]
  stockAdjustments StockAdjustment[]
  receivings       Receiving[]
  transfers          StockTransfer[]
  transfersApproved  StockTransfer[] @relation("TransferApprovedBy")
  transfersReceived  StockTransfer[] @relation("TransferReceivedBy")
  transfersRejected  StockTransfer[] @relation("TransferRejectedBy")
  activityLogs       ActivityLog[]
  auditTemplatesCreated AuditTemplate[] @relation("AuditTemplateCreatedBy")
  auditReports          AuditReport[]   @relation("AuditReportAuditor")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

// ─── ITEM GROUPS ────────────────────────────────────────────

model ItemGroup {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  products Product[]

  @@map("ItemGroup")
}

// ─── STORAGE AREAS ──────────────────────────────────────────

model StorageArea {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique

  @@map("StorageArea")
}

enum ItemType {
  INGREDIENT
  PERISHABLE
}

// ─── INVENTORY ITEMS (Ingredients + Perishables) ────────────

model Product {
  id             String   @id @default(uuid())
  name           String
  sku            String   @unique
  groupId        String
  group          ItemGroup @relation(fields: [groupId], references: [id])
  description    String?
  imageUrl       String?
  itemType       ItemType @default(INGREDIENT)
  baseUom        String
  tags           String[] @default([])
  storageArea    String?
  shelfLifeDays  Int?
  checkFrequency String   @default("MONTHLY")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  packages          ProductPackage[]
  outletProducts    OutletProduct[]
  supplierProducts  SupplierProduct[]
  orderItems        OrderItem[]
  stockCountItems   StockCountItem[]
  stockBalances     StockBalance[]
  stockAdjustments  StockAdjustment[]
  receivingItems    ReceivingItem[]
  parLevels         ParLevel[]
  menuIngredients   MenuIngredient[]
  transferItems     StockTransferItem[]
}

// ─── PRODUCT PACKAGES (Multi-UOM) ──────────────────────────

model ProductPackage {
  id                String  @id @default(uuid())
  productId         String
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String?
  packageName       String
  packageLabel      String
  conversionFactor  Decimal
  isDefault         Boolean @default(false)
  containsPackageId String?
  containsPackage   ProductPackage?  @relation("PackageContains", fields: [containsPackageId], references: [id])
  containedBy       ProductPackage[] @relation("PackageContains")

  supplierProducts SupplierProduct[]
  orderItems       OrderItem[]
  stockCountItems  StockCountItem[]
  receivingItems   ReceivingItem[]
  transferItems    StockTransferItem[]
  stockBalances    StockBalance[]
}

// ─── SUPPLIERS ──────────────────────────────────────────────

model Supplier {
  id           String         @id @default(uuid())
  name         String
  logoUrl      String?
  location     String?
  supplierCode String?        @unique
  phone        String?
  email        String?
  status       SupplierStatus @default(ACTIVE)
  tags         String[]       @default([])
  leadTimeDays Int            @default(1)
  deliveryDays String[]       @default([])  // e.g. ["Monday","Wednesday","Friday"]
  moq              String?
  paymentTerms     String?
  notes            String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  telegramChatId    String?
  depositPercent    Int?               // e.g. 10 for 10%. null = no deposit required
  depositTermsDays  Int?               // days until balance due after deposit paid
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  supplierProducts SupplierProduct[]
  priceHistory     PriceHistory[]
  orders           Order[]
  invoices         Invoice[]
  receivings       Receiving[]
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

// ─── SUPPLIER PRODUCTS (Price List) ─────────────────────────

model SupplierProduct {
  id               String          @id @default(uuid())
  supplierId       String
  supplier         Supplier        @relation(fields: [supplierId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  price            Decimal
  moq              Decimal?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([supplierId, productId, productPackageId])
}

// ─── PRICE HISTORY ──────────────────────────────────────────

model PriceHistory {
  id               String   @id @default(uuid())
  supplierId       String
  supplier         Supplier @relation(fields: [supplierId], references: [id])
  productId        String
  productPackageId String?
  oldPrice         Decimal
  newPrice         Decimal
  changePercent    Decimal
  changedAt        DateTime @default(now())

  @@index([supplierId, changedAt])
}

// ─── OUTLET PRODUCTS ────────────────────────────────────────

model OutletProduct {
  id             String         @id @default(uuid())
  outletId       String
  outlet         Outlet         @relation(fields: [outletId], references: [id])
  productId      String
  product        Product        @relation(fields: [productId], references: [id])
  isActive       Boolean        @default(true)
  countFrequency CountFrequency @default(MONTHLY)

  @@unique([outletId, productId])
}

enum CountFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── ORDERS (Purchase Orders) ───────────────────────────────

model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique
  orderType    OrderType   @default(PURCHASE_ORDER)
  expenseCategory ExpenseCategory @default(INGREDIENT)
  outletId     String
  outlet       Outlet      @relation(fields: [outletId], references: [id])
  supplierId   String?
  supplier     Supplier?   @relation(fields: [supplierId], references: [id])
  status       OrderStatus @default(DRAFT)
  totalAmount  Decimal     @default(0)
  notes        String?
  photos       String[]    @default([])
  deliveryDate DateTime?
  createdById  String
  createdBy    User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?       @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  claimedById  String?
  claimedBy    User?       @relation("OrderClaimedBy", fields: [claimedById], references: [id])
  approvedAt   DateTime?
  sentAt       DateTime?
  confirmedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items      OrderItem[]
  receivings Receiving[]
  invoices   Invoice[]
}

enum OrderType {
  PURCHASE_ORDER
  PAY_AND_CLAIM
  PAYMENT_REQUEST  // Staff requests finance to pay a one-off vendor directly
}

enum ExpenseCategory {
  INGREDIENT
  ASSET
  MAINTENANCE
  OTHER
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  CONFIRMED
  AWAITING_DELIVERY
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

model OrderItem {
  id               String          @id @default(uuid())
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  quantity         Decimal
  unitPrice        Decimal
  totalPrice       Decimal
  notes            String?

  @@unique([orderId, productId, productPackageId])
}

// ─── INVOICES ───────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id])
  transferId    String?
  transfer      StockTransfer? @relation(fields: [transferId], references: [id])
  outletId      String
  outlet        Outlet        @relation(fields: [outletId], references: [id])
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  amount        Decimal
  status        InvoiceStatus @default(DRAFT)
  paymentType   PaymentType?  @default(SUPPLIER)
  expenseCategory ExpenseCategory @default(INGREDIENT)
  claimedById   String?
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  photos        String[]      @default([])
  notes         String?
  // One-off vendor fields — used when there's no Supplier record
  // (typical for ASSET/MAINTENANCE requests where the vendor is a one-time
  // purchase). Supplier relation takes precedence when both are set.
  vendorName              String?
  vendorBankName          String?
  vendorBankAccountNumber String?
  vendorBankAccountName   String?
  paidAt        DateTime?
  paidVia       String?
  paymentRef    String?
  popShortLink  String?
  depositAmount Decimal?              // calculated: amount × supplier.depositPercent / 100
  depositPaidAt DateTime?             // when deposit was paid
  depositRef    String?               // payment reference for deposit
  // Claim batching — Finance groups small staff claims into one transfer.
  // NULL = standalone invoice (existing behaviour). Non-null = settled via batch.
  claimBatchId  String?
  claimBatch    HrClaimBatch? @relation(fields: [claimBatchId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Groups staff-claim invoices for single-transfer reimbursement.
// One batch = one payee = one bank transfer in M2U.
model HrClaimBatch {
  id            String    @id @default(uuid())
  batchNumber   String    @unique
  userId        String    // payee (staff being reimbursed)
  totalAmount   Decimal   // sum of linked Invoice.amount
  status        String    @default("OPEN")  // OPEN | PAID | CANCELLED
  paymentRef    String?   // Maybank Reference ID after payment
  paidAt        DateTime?
  paidById      String?
  paidVia       String?   @default("bank_transfer")
  notes         String?
  invoices      Invoice[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
}

enum InvoiceStatus {
  DRAFT
  INITIATED
  PENDING
  DEPOSIT_PAID
  PAID
  OVERDUE
}

enum PaymentType {
  SUPPLIER
  PAY_CLAIM
  STAFF_CLAIM
  INTERNAL_TRANSFER
}

// ─── RECEIVING (Goods Received) ─────────────────────────────

model Receiving {
  id            String          @id @default(uuid())
  orderId       String?
  order         Order?          @relation(fields: [orderId], references: [id])
  transferId    String?
  transfer      StockTransfer?  @relation(fields: [transferId], references: [id])
  outletId      String
  outlet        Outlet          @relation(fields: [outletId], references: [id])
  supplierId    String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  receivedById  String
  receivedBy    User            @relation(fields: [receivedById], references: [id])
  receivedAt    DateTime        @default(now())
  status        ReceivingStatus @default(COMPLETE)
  invoicePhotos String[]        @default([])
  notes         String?
  createdAt     DateTime        @default(now())

  items ReceivingItem[]
}

enum ReceivingStatus {
  COMPLETE
  PARTIAL
  DISPUTED
}

model ReceivingItem {
  id                String          @id @default(uuid())
  receivingId       String
  receiving         Receiving       @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  productPackageId  String?
  productPackage    ProductPackage? @relation(fields: [productPackageId], references: [id])
  orderedQty        Decimal?
  receivedQty       Decimal
  expiryDate        DateTime?
  discrepancyReason String?
}

// ─── STOCK COUNTS ───────────────────────────────────────────

model StockCount {
  id          String           @id @default(uuid())
  outletId    String
  outlet      Outlet           @relation(fields: [outletId], references: [id])
  frequency   CountFrequency
  countedById String
  countedBy   User             @relation(fields: [countedById], references: [id])
  countDate   DateTime         @default(now())
  status      StockCountStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime         @default(now())
  submittedAt DateTime?
  reviewedAt  DateTime?

  items StockCountItem[]
}

enum StockCountStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

model StockCountItem {
  id               String     @id @default(uuid())
  stockCountId     String
  stockCount       StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  productId        String
  product          Product    @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  expectedQty      Decimal?
  countedQty       Decimal?
  isConfirmed      Boolean    @default(false)
  varianceReason   String?

  @@unique([stockCountId, productId, productPackageId])
}

// ─── STOCK BALANCES ─────────────────────────────────────────

model StockBalance {
  id               String          @id @default(uuid())
  outletId         String
  outlet           Outlet          @relation(fields: [outletId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  quantity         Decimal         @default(0)
  lastUpdated      DateTime        @default(now())

  @@unique([outletId, productId, productPackageId])
}

// ─── STOCK ADJUSTMENTS ──────────────────────────────────────

model StockAdjustment {
  id             String         @id @default(uuid())
  outletId       String
  outlet         Outlet         @relation(fields: [outletId], references: [id])
  productId      String
  product        Product        @relation(fields: [productId], references: [id])
  adjustmentType AdjustmentType
  quantity       Decimal
  costAmount     Decimal?
  reason         String?
  photoUrl       String?
  adjustedById   String
  adjustedBy     User           @relation(fields: [adjustedById], references: [id])
  stockCountId   String?
  createdAt      DateTime       @default(now())
}

enum AdjustmentType {
  WASTAGE
  BREAKAGE
  EXPIRED
  THEFT
  CORRECTION
  SPILLAGE
  USED_NOT_RECORDED
}

// ─── STOCK TRANSFERS ────────────────────────────────────────

model StockTransfer {
  id              String         @id @default(uuid())
  fromOutletId    String
  fromOutlet      Outlet         @relation("TransferFrom", fields: [fromOutletId], references: [id])
  toOutletId      String
  toOutlet        Outlet         @relation("TransferTo", fields: [toOutletId], references: [id])
  status          TransferStatus @default(PENDING)
  transferredById String
  transferredBy   User           @relation(fields: [transferredById], references: [id])
  notes           String?
  approvedById    String?
  approvedBy      User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  receivedById    String?
  receivedBy      User?          @relation("TransferReceivedBy", fields: [receivedById], references: [id])
  receivedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?          @relation("TransferRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  completedAt     DateTime?

  items      StockTransferItem[]
  receivings Receiving[]
  invoices   Invoice[]
}

enum TransferStatus {
  DRAFT
  PENDING_APPROVAL
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  COMPLETED
  CANCELLED
}

model StockTransferItem {
  id               String          @id @default(uuid())
  transferId       String
  transfer         StockTransfer   @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  quantity         Decimal
}

// ─── PAR LEVELS ─────────────────────────────────────────────

model ParLevel {
  id             String   @id @default(uuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  outletId       String
  outlet         Outlet   @relation(fields: [outletId], references: [id])
  parLevel       Decimal
  reorderPoint   Decimal
  maxLevel       Decimal?
  avgDailyUsage  Decimal?
  lastCalculated DateTime?

  @@unique([productId, outletId])
}

// ─── MENUS (from StoreHub) ──────────────────────────────────

model Menu {
  id           String   @id @default(uuid())
  name         String
  category     String?
  sellingPrice Decimal?
  storehubId   String   @unique
  isActive     Boolean  @default(true)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ingredients MenuIngredient[]
  salesData   SalesTransaction[]
}

model MenuIngredient {
  id           String  @id @default(uuid())
  menuId       String
  menu         Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantityUsed Decimal
  uom          String

  @@unique([menuId, productId])
}

// ─── SALES TRANSACTIONS (from StoreHub) ─────────────────────

model SalesTransaction {
  id           String   @id @default(uuid())
  storehubTxId String   @unique
  outletId     String
  outlet       Outlet   @relation(fields: [outletId], references: [id])
  menuId       String?
  menu         Menu?    @relation(fields: [menuId], references: [id])
  menuName     String
  quantity     Int
  grossAmount  Decimal
  transactedAt DateTime
  syncedAt     DateTime @default(now())

  @@index([outletId, transactedAt])
  @@index([menuId])
}

// ─── SALES TARGETS (AI-set, progressive) ─────────────────────

model SalesTarget {
  id            String   @id @default(uuid())
  roundKey      String   // breakfast | brunch | lunch | midday | evening | dinner | supper
  dayType       String   // weekday | weekend
  revenue       Int      // target revenue per outlet per day (RM)
  orders        Int      // target orders per outlet per day
  aov           Decimal  @db.Decimal(10, 2) // target AOV per outlet per day
  source        String   @default("ai")     // ai | manual | default
  reasoning     String?  @db.Text           // AI explanation (why this target)
  priorRevenue  Int?     // what the prior active target was (for audit)
  effectiveFrom DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([roundKey, dayType, isActive])
  @@index([effectiveFrom])
}

// ─── STOREHUB SYNC STATUS ───────────────────────────────────

model StorehubSync {
  id          String       @id @default(uuid())
  outletId    String
  outlet      Outlet       @relation(fields: [outletId], references: [id])
  syncType    SyncType
  status      SyncStatus   @default(SUCCESS)
  lastSyncAt  DateTime     @default(now())
  recordCount Int          @default(0)
  errorMessage String?
  createdAt   DateTime     @default(now())

  @@index([outletId, syncType, lastSyncAt])
}

enum SyncType {
  PRODUCTS
  SALES
  EMPLOYEES
}

enum SyncStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
}

// ─── APPROVAL RULES ────────────────────────────────────────

model ApprovalRule {
  id          String             @id @default(uuid())
  name        String
  ruleType    ApprovalRuleType
  condition   String
  threshold   Decimal?
  outlets     String[]           @default([])
  approverIds String[]           @default([])
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum ApprovalRuleType {
  ORDER_APPROVAL
  STOCK_ADJUSTMENT
  STOCK_TRANSFER
  CREDIT_NOTE
}

// ─── ACTIVITY LOG ───────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  module     String
  details    String?
  targetId   String?
  targetName String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([module, createdAt])
}

// ─── SOPs (Standard Operating Procedures) ──────────────────

model SopCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sops Sop[]
}

model Sop {
  id          String      @id @default(uuid())
  title       String
  description String?
  categoryId  String
  category    SopCategory @relation(fields: [categoryId], references: [id])
  content     String?
  status      SopStatus   @default(DRAFT)
  sortOrder   Int         @default(0)
  version     Int         @default(1)
  createdById String
  createdBy   User        @relation("SopCreatedBy", fields: [createdById], references: [id])
  publishedAt DateTime?
  // Expected frequency — for compliance gap detection
  expectedRecurrence  ScheduleRecurrence @default(SHIFT)
  expectedTimesPerDay Int                @default(1)   // how many times per day
  expectedTimes       String[]           @default([])  // ["08:00","12:00","16:00"]
  expectedDueMinutes  Int                @default(0)   // 0 = no deadline
  expectedDaysOfWeek  Int[]             @default([])  // empty = every day, [1]=Mon...[7]=Sun
  appliesToAllOutlets Boolean            @default(true) // should be at every outlet?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  steps      SopStep[]
  sopOutlets SopOutlet[]
  checklists Checklist[]
  schedules  SopSchedule[]

  @@index([categoryId])
  @@index([status])
}

enum SopStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model SopStep {
  id            String  @id @default(uuid())
  sopId         String
  sop           Sop     @relation(fields: [sopId], references: [id], onDelete: Cascade)
  stepNumber    Int
  title         String
  description   String?
  imageUrl      String?
  photoRequired Boolean @default(false)

  @@unique([sopId, stepNumber])
  @@index([sopId])
}

model SopOutlet {
  id         String   @id @default(uuid())
  sopId      String
  sop        Sop      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  outletId   String
  outlet     Outlet   @relation(fields: [outletId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([sopId, outletId])
  @@index([outletId])
}

// ─── CHECKLISTS (Daily SOP Instances) ──────────────────────

model Checklist {
  id            String          @id @default(uuid())
  sopId         String
  sop           Sop             @relation(fields: [sopId], references: [id])
  outletId      String
  outlet        Outlet          @relation(fields: [outletId], references: [id])
  assignedToId  String?
  assignedTo    User?           @relation("ChecklistAssignedTo", fields: [assignedToId], references: [id])
  date          DateTime        @db.Date
  shift         Shift           @default(OPENING)
  timeSlot      String?                        // "08:00", "14:00" etc — null for shift-only
  dueAt         DateTime?                      // exact due time for this instance
  status        ChecklistStatus @default(PENDING)
  completedById String?
  completedBy   User?           @relation("ChecklistCompletedBy", fields: [completedById], references: [id])
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items ChecklistItem[]

  @@unique([sopId, outletId, date, shift, assignedToId, timeSlot])
  @@index([outletId, date])
  @@index([assignedToId, date])
  @@index([status])
}

enum Shift {
  OPENING
  MIDDAY
  CLOSING
}

enum ChecklistStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model ChecklistItem {
  id            String     @id @default(uuid())
  checklistId   String
  checklist     Checklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  stepNumber    Int
  title         String
  description   String?
  photoRequired Boolean    @default(false)
  isCompleted   Boolean    @default(false)
  completedById String?
  completedBy   User?      @relation("ChecklistItemCompletedBy", fields: [completedById], references: [id])
  completedAt   DateTime?
  notes         String?
  photoUrl      String?

  @@index([checklistId])
}

// ─── SOP SCHEDULES (Recurring Assignments) ─────────────────

model SopSchedule {
  id           String         @id @default(uuid())
  sopId        String
  sop          Sop            @relation(fields: [sopId], references: [id], onDelete: Cascade)
  outletId     String
  outlet       Outlet         @relation(fields: [outletId], references: [id])
  assignedToId String
  assignedTo   User           @relation("ScheduleAssignedTo", fields: [assignedToId], references: [id])
  shift        Shift          @default(OPENING)
  recurrence   ScheduleRecurrence @default(SHIFT)
  times        String[]       @default([])    // ["08:00","12:00","16:00"]
  dueMinutes   Int            @default(0)     // 0 = no deadline, 30 = must complete within 30min
  daysOfWeek   Int[]          @default([1, 2, 3, 4, 5, 6, 7]) // 1=Mon, 7=Sun
  isActive     Boolean        @default(true)
  startDate    DateTime?      @db.Date
  endDate      DateTime?      @db.Date
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([sopId, outletId, assignedToId, shift])
  @@index([outletId])
  @@index([assignedToId])
}

enum ScheduleRecurrence {
  SHIFT           // Once per shift (current behavior)
  SPECIFIC_TIMES  // At specific times: ["08:00","12:00","16:00"]
  HOURLY          // Every hour during operating hours
}

// ─── AUDIT TEMPLATES & REPORTS ─────────────────────────────

model AuditTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  roleType    String   // "barista_head", "chef_head", "area_manager"
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdById String
  createdBy   User     @relation("AuditTemplateCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections AuditSection[]
  reports  AuditReport[]

  @@index([roleType])
  @@index([isActive])
}

model AuditSection {
  id         String        @id @default(uuid())
  templateId String
  template   AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int           @default(0)

  items AuditSectionItem[]

  @@index([templateId])
}

model AuditSectionItem {
  id            String       @id @default(uuid())
  sectionId     String
  section       AuditSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  photoRequired Boolean      @default(false)
  ratingType    String       @default("pass_fail") // "pass_fail", "rating_5", "rating_3"
  sortOrder     Int          @default(0)

  @@index([sectionId])
}

model AuditReport {
  id           String        @id @default(uuid())
  templateId   String
  template     AuditTemplate @relation(fields: [templateId], references: [id])
  outletId     String
  outlet       Outlet        @relation(fields: [outletId], references: [id])
  auditorId    String
  auditor      User          @relation("AuditReportAuditor", fields: [auditorId], references: [id])
  date         DateTime      @db.Date
  status       String        @default("IN_PROGRESS") // "IN_PROGRESS", "COMPLETED"
  overallScore Decimal?
  overallNotes String?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  items AuditReportItem[]

  @@index([outletId, date])
  @@index([auditorId, date])
  @@index([templateId])
  @@index([status])
}

model AuditReportItem {
  id        String      @id @default(uuid())
  reportId  String
  report    AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sectionName String
  itemTitle   String
  sortOrder   Int         @default(0)
  photoRequired Boolean   @default(false)
  ratingType    String    @default("pass_fail")
  // Response
  rating    Int?         // pass_fail: 1=pass,0=fail; rating_5: 1-5; rating_3: 1-3
  notes     String?
  photos    String[]     @default([])

  @@index([reportId])
}

// ─── REVIEWS ───────────────────────────────────────────────

model ReviewSettings {
  id              String  @id @default(uuid())
  outletId        String  @unique
  outlet          Outlet  @relation(fields: [outletId], references: [id])
  // Google Business Profile
  gbpPlaceId      String?
  gbpAccountId    String?
  gbpLocationName String?
  googleReviewUrl String?
  // QR rating gate
  ratingThreshold Int     @default(4) // >= this → redirect to Google
  // Review page branding
  heading         String?
  description     String?
  logoUrl         String?
  // Feedback form fields config (JSON array of {question, type, required, active})
  feedbackFields  Json?   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InternalFeedback {
  id        String   @id @default(uuid())
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  rating    Int      // 1-5
  name      String?
  phone     String?
  feedback  String?
  source    String   @default("qr") // "qr" | "manual"
  createdAt DateTime @default(now())

  @@index([outletId, createdAt])
}

// ─── ADS MODULE ─────────────────────────────────────────────
// Google Ads performance + invoice tracking.
// MCC: 415-243-7144, child account: 890-356-3535.
// Tables created by manual SQL migration (apps/backoffice/supabase/migrations/001_ads_module.sql).
// These Prisma models mirror that schema for type-safety only — never `prisma db push`.

model AdsAccount {
  id              String   @id
  customerId      String   @unique @map("customer_id")
  descriptiveName String   @map("descriptive_name")
  currencyCode    String   @default("MYR") @map("currency_code")
  timeZone        String   @default("Asia/Kuala_Lumpur") @map("time_zone")
  isManager       Boolean  @default(false) @map("is_manager")
  isTestAccount   Boolean  @default(false) @map("is_test_account")
  outletId        String?  @map("outlet_id")
  status          String   @default("ACTIVE")
  lastSyncedAt    DateTime? @map("last_synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  campaigns AdsCampaign[]
  metrics   AdsMetricDaily[]
  invoices  AdsInvoice[]
  syncLogs  AdsSyncLog[]

  @@index([outletId])
  @@map("ads_account")
}

model AdsCampaign {
  id                      String    @id
  campaignId              String    @map("campaign_id")
  accountId               String    @map("account_id")
  name                    String
  status                  String    // ENABLED | PAUSED | REMOVED
  advertisingChannelType  String    @map("advertising_channel_type")
  startDate               DateTime? @map("start_date") @db.Date
  endDate                 DateTime? @map("end_date") @db.Date
  dailyBudgetMicros       BigInt?   @map("daily_budget_micros")
  outletId                String?   @map("outlet_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at")

  account   AdsAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metrics   AdsMetricDaily[]
  keywords  AdsKeywordMetric[]

  @@unique([accountId, campaignId])
  @@index([accountId])
  @@index([outletId])
  @@index([status])
  @@map("ads_campaign")
}

model AdsMetricDaily {
  id                String   @id
  date              DateTime @db.Date
  accountId         String   @map("account_id")
  campaignId        String?  @map("campaign_id")
  impressions       BigInt   @default(0)
  clicks            BigInt   @default(0)
  conversions       Decimal  @default(0) @db.Decimal(14, 4)
  conversionsValue  Decimal  @default(0) @map("conversions_value") @db.Decimal(14, 4)
  costMicros        BigInt   @default(0) @map("cost_micros")
  avgCpcMicros      BigInt?  @map("avg_cpc_micros")
  ctr               Decimal? @db.Decimal(8, 6)
  syncedAt          DateTime @default(now()) @map("synced_at")

  account  AdsAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign AdsCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([date, accountId, campaignId])
  @@index([date(sort: Desc)])
  @@index([accountId, date(sort: Desc)])
  @@index([campaignId, date(sort: Desc)])
  @@map("ads_metric_daily")
}

model AdsKeywordMetric {
  id           String   @id
  date         DateTime @db.Date
  campaignId   String   @map("campaign_id")
  adGroupId    String   @map("ad_group_id")
  criterionId  String   @map("criterion_id")
  keywordText  String   @map("keyword_text")
  matchType    String   @map("match_type")
  impressions  BigInt   @default(0)
  clicks       BigInt   @default(0)
  conversions  Decimal  @default(0) @db.Decimal(14, 4)
  costMicros   BigInt   @default(0) @map("cost_micros")
  syncedAt     DateTime @default(now()) @map("synced_at")

  campaign AdsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([date, campaignId, adGroupId, criterionId])
  @@index([date(sort: Desc)])
  @@index([campaignId, date(sort: Desc)])
  @@map("ads_keyword_metric")
}

model AdsInvoice {
  id                    String   @id
  invoiceId             String   @unique @map("invoice_id")
  accountId             String   @map("account_id")
  issueDate             DateTime @map("issue_date") @db.Date
  dueDate               DateTime? @map("due_date") @db.Date
  billingPeriodStart    DateTime @map("billing_period_start") @db.Date
  billingPeriodEnd      DateTime @map("billing_period_end") @db.Date
  currencyCode          String   @default("MYR") @map("currency_code")
  subtotalMicros        BigInt   @default(0) @map("subtotal_micros")
  adjustmentsMicros     BigInt   @default(0) @map("adjustments_micros")
  regulatoryCostsMicros BigInt   @default(0) @map("regulatory_costs_micros")
  taxMicros             BigInt   @default(0) @map("tax_micros")
  totalMicros           BigInt   @default(0) @map("total_micros")
  status                String
  pdfSourceUrl          String?  @map("pdf_source_url")
  pdfStoragePath        String?  @map("pdf_storage_path")
  pdfHashSha256         String?  @map("pdf_hash_sha256")
  pdfSizeBytes          Int?     @map("pdf_size_bytes")
  syncedAt              DateTime @default(now()) @map("synced_at")
  createdAt             DateTime @default(now()) @map("created_at")

  account AdsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, issueDate(sort: Desc)])
  @@index([billingPeriodStart(sort: Desc)])
  @@index([status])
  @@map("ads_invoice")
}

model AdsSyncLog {
  id            String    @id
  kind          String    // metrics-daily | metrics-backfill | invoices | keywords | accounts
  accountId     String?   @map("account_id")
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  status        String    @default("RUNNING")
  rowsInserted  Int?      @map("rows_inserted")
  rowsUpdated   Int?      @map("rows_updated")
  errorMessage  String?   @map("error_message")
  metadata      Json?

  account AdsAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([startedAt(sort: Desc)])
  @@index([kind, startedAt(sort: Desc)])
  @@map("ads_sync_log")
}

model AdsConversionDaily {
  id                    String   @id
  date                  DateTime @db.Date
  accountId             String   @map("account_id")
  campaignId            String   @map("campaign_id")
  conversionActionId    String   @map("conversion_action_id")
  conversionActionName  String   @map("conversion_action_name")
  conversionCategory    String   @map("conversion_category")
  conversions           Decimal  @default(0) @db.Decimal(14, 4)
  conversionsValue      Decimal  @default(0) @map("conversions_value") @db.Decimal(14, 4)
  syncedAt              DateTime @default(now()) @map("synced_at")

  @@unique([date, campaignId, conversionActionId])
  @@index([date(sort: Desc)])
  @@index([campaignId, date(sort: Desc)])
  @@index([conversionCategory])
  @@map("ads_conversion_daily")
}

model AdsPayment {
  id                String    @id
  yearMonth         String    @map("year_month")
  outletId          String?   @map("outlet_id")
  campaignId        String?   @map("campaign_id")
  subtotalMicros    BigInt    @default(0) @map("subtotal_micros")
  taxMicros         BigInt    @default(0) @map("tax_micros")
  totalMicros       BigInt    @default(0) @map("total_micros")
  currencyCode      String    @default("MYR") @map("currency_code")
  status            String    @default("INITIATED")
  paidAt            DateTime? @map("paid_at")
  paidByUserId      String?   @map("paid_by_user_id")
  paymentMethod     String?   @map("payment_method")
  referenceNumber   String?   @map("reference_number")
  popPhotos         String[]  @default([]) @map("pop_photos")
  popTelegramToken  String?   @unique @map("pop_telegram_token")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([yearMonth(sort: Desc)])
  @@index([status])
  @@index([outletId])
  @@index([campaignId])
  @@map("ads_payment")
}

model AdsSettings {
  id                  String   @id @default("singleton")
  mccCustomerId       String?  @map("mcc_customer_id")
  dailySyncEnabled    Boolean  @default(true) @map("daily_sync_enabled")
  keywordSyncEnabled  Boolean  @default(true) @map("keyword_sync_enabled")
  invoiceSyncEnabled  Boolean  @default(true) @map("invoice_sync_enabled")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("ads_settings")
}
