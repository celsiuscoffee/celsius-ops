generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── APP CONFIG ────────────────────────────────────────────
model AppConfig {
  key       String   @id
  value     Json     @default("{}")
  updatedAt DateTime @default(now()) @updatedAt
}

// ─── OUTLETS ────────────────────────────────────────────────

model Outlet {
  id        String       @id @default(uuid())
  code      String       @unique
  name      String
  type      OutletType   @default(OUTLET)
  address   String
  city      String
  state     String
  phone     String?
  status    OutletStatus @default(ACTIVE)
  storehubId String?     @unique

  // Location & hours
  lat            Decimal?
  lng            Decimal?
  openTime       String?  @default("08:00")
  closeTime      String?  @default("22:00")
  daysOpen       Int[]    @default([1, 2, 3, 4, 5, 6, 7])
  isOpen         Boolean? @default(false)
  isBusy         Boolean? @default(false)
  pickupTimeMins Int?     @default(15)

  // Cross-app references
  pickupStoreId   String?  @unique  // Supabase outlet_settings.store_id (e.g. "shah-alam")
  loyaltyOutletId String?
  staffPin        String?

  // Stripe Connect
  stripeAccountId  String?
  stripeOnboarded  Boolean? @default(false)
  stripeEnabled    Boolean? @default(false)

  // Revenue Monster
  rmMerchantId   String?
  rmClientId     String?
  rmClientSecret String?
  rmPrivateKey   String?
  rmIsProduction Boolean? @default(false)
  rmEnabled      Boolean? @default(false)

  // Bukku accounting
  bukkuToken     String?
  bukkuSubdomain String?
  bukkuEnabled   Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  outletProducts    OutletProduct[]
  orders            Order[]
  invoices          Invoice[]
  stockCounts       StockCount[]
  stockBalances     StockBalance[]
  stockAdjustments  StockAdjustment[]
  receivings        Receiving[]
  parLevels         ParLevel[]
  transfersFrom     StockTransfer[] @relation("TransferFrom")
  transfersTo       StockTransfer[] @relation("TransferTo")
  storehubSyncs     StorehubSync[]
  salesTransactions SalesTransaction[]
  sopOutlets        SopOutlet[]
  checklists        Checklist[]
  sopSchedules      SopSchedule[]
  reviewSettings    ReviewSettings?
  internalFeedbacks InternalFeedback[]
}

enum OutletType {
  OUTLET
  CENTRAL_KITCHEN
}

enum OutletStatus {
  ACTIVE
  INACTIVE
}

// ─── USERS ──────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  name         String
  email        String?    @unique
  phone        String     @unique
  role         UserRole
  outletId     String?
  outlet       Outlet?    @relation(fields: [outletId], references: [id])
  username     String?    @unique
  passwordHash String?
  pin          String?
  status       UserStatus @default(ACTIVE)
  outletIds    String[]   @default([])
  appAccess    String[]   @default([])
  moduleAccess Json?      @default("{}")
  permissions  String[]   @default([])
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ordersCreated    Order[]           @relation("OrderCreatedBy")
  ordersApproved   Order[]           @relation("OrderApprovedBy")
  ordersClaimed    Order[]           @relation("OrderClaimedBy")
  sopsCreated      Sop[]             @relation("SopCreatedBy")
  checklistsCompleted Checklist[]    @relation("ChecklistCompletedBy")
  checklistItems   ChecklistItem[]   @relation("ChecklistItemCompletedBy")
  sopSchedules     SopSchedule[]     @relation("ScheduleAssignedTo")
  checklistsAssigned Checklist[]     @relation("ChecklistAssignedTo")
  stockCounts      StockCount[]
  stockAdjustments StockAdjustment[]
  receivings       Receiving[]
  transfers          StockTransfer[]
  transfersApproved  StockTransfer[] @relation("TransferApprovedBy")
  transfersReceived  StockTransfer[] @relation("TransferReceivedBy")
  transfersRejected  StockTransfer[] @relation("TransferRejectedBy")
  activityLogs       ActivityLog[]
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

// ─── ITEM GROUPS ────────────────────────────────────────────

model ItemGroup {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  products Product[]

  @@map("ItemGroup")
}

// ─── STORAGE AREAS ──────────────────────────────────────────

model StorageArea {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique

  @@map("StorageArea")
}

enum ItemType {
  INGREDIENT
  PERISHABLE
}

// ─── INVENTORY ITEMS (Ingredients + Perishables) ────────────

model Product {
  id             String   @id @default(uuid())
  name           String
  sku            String   @unique
  groupId        String
  group          ItemGroup @relation(fields: [groupId], references: [id])
  description    String?
  imageUrl       String?
  itemType       ItemType @default(INGREDIENT)
  baseUom        String
  tags           String[] @default([])
  storageArea    String?
  shelfLifeDays  Int?
  checkFrequency String   @default("MONTHLY")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  packages          ProductPackage[]
  outletProducts    OutletProduct[]
  supplierProducts  SupplierProduct[]
  orderItems        OrderItem[]
  stockCountItems   StockCountItem[]
  stockBalances     StockBalance[]
  stockAdjustments  StockAdjustment[]
  receivingItems    ReceivingItem[]
  parLevels         ParLevel[]
  menuIngredients   MenuIngredient[]
  transferItems     StockTransferItem[]
}

// ─── PRODUCT PACKAGES (Multi-UOM) ──────────────────────────

model ProductPackage {
  id                String  @id @default(uuid())
  productId         String
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String?
  packageName       String
  packageLabel      String
  conversionFactor  Decimal
  isDefault         Boolean @default(false)
  containsPackageId String?
  containsPackage   ProductPackage?  @relation("PackageContains", fields: [containsPackageId], references: [id])
  containedBy       ProductPackage[] @relation("PackageContains")

  supplierProducts SupplierProduct[]
  orderItems       OrderItem[]
  stockCountItems  StockCountItem[]
  receivingItems   ReceivingItem[]
  transferItems    StockTransferItem[]
  stockBalances    StockBalance[]
}

// ─── SUPPLIERS ──────────────────────────────────────────────

model Supplier {
  id           String         @id @default(uuid())
  name         String
  logoUrl      String?
  location     String?
  supplierCode String?        @unique
  phone        String?
  email        String?
  status       SupplierStatus @default(ACTIVE)
  tags         String[]       @default([])
  leadTimeDays Int            @default(1)
  deliveryDays String[]       @default([])  // e.g. ["Monday","Wednesday","Friday"]
  moq              String?
  paymentTerms     String?
  notes            String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  telegramChatId    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  supplierProducts SupplierProduct[]
  priceHistory     PriceHistory[]
  orders           Order[]
  invoices         Invoice[]
  receivings       Receiving[]
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

// ─── SUPPLIER PRODUCTS (Price List) ─────────────────────────

model SupplierProduct {
  id               String          @id @default(uuid())
  supplierId       String
  supplier         Supplier        @relation(fields: [supplierId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  price            Decimal
  moq              Decimal?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([supplierId, productId, productPackageId])
}

// ─── PRICE HISTORY ──────────────────────────────────────────

model PriceHistory {
  id               String   @id @default(uuid())
  supplierId       String
  supplier         Supplier @relation(fields: [supplierId], references: [id])
  productId        String
  productPackageId String?
  oldPrice         Decimal
  newPrice         Decimal
  changePercent    Decimal
  changedAt        DateTime @default(now())

  @@index([supplierId, changedAt])
}

// ─── OUTLET PRODUCTS ────────────────────────────────────────

model OutletProduct {
  id             String         @id @default(uuid())
  outletId       String
  outlet         Outlet         @relation(fields: [outletId], references: [id])
  productId      String
  product        Product        @relation(fields: [productId], references: [id])
  isActive       Boolean        @default(true)
  countFrequency CountFrequency @default(MONTHLY)

  @@unique([outletId, productId])
}

enum CountFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── ORDERS (Purchase Orders) ───────────────────────────────

model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique
  orderType    OrderType   @default(PURCHASE_ORDER)
  outletId     String
  outlet       Outlet      @relation(fields: [outletId], references: [id])
  supplierId   String?
  supplier     Supplier?   @relation(fields: [supplierId], references: [id])
  status       OrderStatus @default(DRAFT)
  totalAmount  Decimal     @default(0)
  notes        String?
  deliveryDate DateTime?
  createdById  String
  createdBy    User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?       @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  claimedById  String?
  claimedBy    User?       @relation("OrderClaimedBy", fields: [claimedById], references: [id])
  approvedAt   DateTime?
  sentAt       DateTime?
  confirmedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items      OrderItem[]
  receivings Receiving[]
  invoices   Invoice[]
}

enum OrderType {
  PURCHASE_ORDER
  PAY_AND_CLAIM
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  CONFIRMED
  AWAITING_DELIVERY
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

model OrderItem {
  id               String          @id @default(uuid())
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  quantity         Decimal
  unitPrice        Decimal
  totalPrice       Decimal
  notes            String?

  @@unique([orderId, productId, productPackageId])
}

// ─── INVOICES ───────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id])
  transferId    String?
  transfer      StockTransfer? @relation(fields: [transferId], references: [id])
  outletId      String
  outlet        Outlet        @relation(fields: [outletId], references: [id])
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  amount        Decimal
  status        InvoiceStatus @default(DRAFT)
  paymentType   PaymentType?  @default(SUPPLIER)
  claimedById   String?
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  photos        String[]      @default([])
  notes         String?
  paidAt        DateTime?
  paidVia       String?
  paymentRef    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum InvoiceStatus {
  DRAFT
  INITIATED
  PENDING
  PAID
  OVERDUE
}

enum PaymentType {
  SUPPLIER
  PAY_CLAIM
  STAFF_CLAIM
  INTERNAL_TRANSFER
}

// ─── RECEIVING (Goods Received) ─────────────────────────────

model Receiving {
  id            String          @id @default(uuid())
  orderId       String?
  order         Order?          @relation(fields: [orderId], references: [id])
  transferId    String?
  transfer      StockTransfer?  @relation(fields: [transferId], references: [id])
  outletId      String
  outlet        Outlet          @relation(fields: [outletId], references: [id])
  supplierId    String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  receivedById  String
  receivedBy    User            @relation(fields: [receivedById], references: [id])
  receivedAt    DateTime        @default(now())
  status        ReceivingStatus @default(COMPLETE)
  invoicePhotos String[]        @default([])
  notes         String?
  createdAt     DateTime        @default(now())

  items ReceivingItem[]
}

enum ReceivingStatus {
  COMPLETE
  PARTIAL
  DISPUTED
}

model ReceivingItem {
  id                String          @id @default(uuid())
  receivingId       String
  receiving         Receiving       @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  productPackageId  String?
  productPackage    ProductPackage? @relation(fields: [productPackageId], references: [id])
  orderedQty        Decimal?
  receivedQty       Decimal
  expiryDate        DateTime?
  discrepancyReason String?
}

// ─── STOCK COUNTS ───────────────────────────────────────────

model StockCount {
  id          String           @id @default(uuid())
  outletId    String
  outlet      Outlet           @relation(fields: [outletId], references: [id])
  frequency   CountFrequency
  countedById String
  countedBy   User             @relation(fields: [countedById], references: [id])
  countDate   DateTime         @default(now())
  status      StockCountStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime         @default(now())
  submittedAt DateTime?
  reviewedAt  DateTime?

  items StockCountItem[]
}

enum StockCountStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

model StockCountItem {
  id               String     @id @default(uuid())
  stockCountId     String
  stockCount       StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  productId        String
  product          Product    @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  expectedQty      Decimal?
  countedQty       Decimal?
  isConfirmed      Boolean    @default(false)
  varianceReason   String?

  @@unique([stockCountId, productId, productPackageId])
}

// ─── STOCK BALANCES ─────────────────────────────────────────

model StockBalance {
  id               String          @id @default(uuid())
  outletId         String
  outlet           Outlet          @relation(fields: [outletId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  quantity         Decimal         @default(0)
  lastUpdated      DateTime        @default(now())

  @@unique([outletId, productId, productPackageId])
}

// ─── STOCK ADJUSTMENTS ──────────────────────────────────────

model StockAdjustment {
  id             String         @id @default(uuid())
  outletId       String
  outlet         Outlet         @relation(fields: [outletId], references: [id])
  productId      String
  product        Product        @relation(fields: [productId], references: [id])
  adjustmentType AdjustmentType
  quantity       Decimal
  costAmount     Decimal?
  reason         String?
  photoUrl       String?
  adjustedById   String
  adjustedBy     User           @relation(fields: [adjustedById], references: [id])
  stockCountId   String?
  createdAt      DateTime       @default(now())
}

enum AdjustmentType {
  WASTAGE
  BREAKAGE
  EXPIRED
  THEFT
  CORRECTION
  SPILLAGE
  USED_NOT_RECORDED
}

// ─── STOCK TRANSFERS ────────────────────────────────────────

model StockTransfer {
  id              String         @id @default(uuid())
  fromOutletId    String
  fromOutlet      Outlet         @relation("TransferFrom", fields: [fromOutletId], references: [id])
  toOutletId      String
  toOutlet        Outlet         @relation("TransferTo", fields: [toOutletId], references: [id])
  status          TransferStatus @default(PENDING)
  transferredById String
  transferredBy   User           @relation(fields: [transferredById], references: [id])
  notes           String?
  approvedById    String?
  approvedBy      User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  receivedById    String?
  receivedBy      User?          @relation("TransferReceivedBy", fields: [receivedById], references: [id])
  receivedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?          @relation("TransferRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  completedAt     DateTime?

  items      StockTransferItem[]
  receivings Receiving[]
  invoices   Invoice[]
}

enum TransferStatus {
  DRAFT
  PENDING_APPROVAL
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  COMPLETED
  CANCELLED
}

model StockTransferItem {
  id               String          @id @default(uuid())
  transferId       String
  transfer         StockTransfer   @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id])
  quantity         Decimal
}

// ─── PAR LEVELS ─────────────────────────────────────────────

model ParLevel {
  id             String   @id @default(uuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  outletId       String
  outlet         Outlet   @relation(fields: [outletId], references: [id])
  parLevel       Decimal
  reorderPoint   Decimal
  maxLevel       Decimal?
  avgDailyUsage  Decimal?
  lastCalculated DateTime?

  @@unique([productId, outletId])
}

// ─── MENUS (from StoreHub) ──────────────────────────────────

model Menu {
  id           String   @id @default(uuid())
  name         String
  category     String?
  sellingPrice Decimal?
  storehubId   String   @unique
  isActive     Boolean  @default(true)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ingredients MenuIngredient[]
  salesData   SalesTransaction[]
}

model MenuIngredient {
  id           String  @id @default(uuid())
  menuId       String
  menu         Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantityUsed Decimal
  uom          String

  @@unique([menuId, productId])
}

// ─── SALES TRANSACTIONS (from StoreHub) ─────────────────────

model SalesTransaction {
  id           String   @id @default(uuid())
  storehubTxId String   @unique
  outletId     String
  outlet       Outlet   @relation(fields: [outletId], references: [id])
  menuId       String?
  menu         Menu?    @relation(fields: [menuId], references: [id])
  menuName     String
  quantity     Int
  grossAmount  Decimal
  transactedAt DateTime
  syncedAt     DateTime @default(now())

  @@index([outletId, transactedAt])
  @@index([menuId])
}

// ─── STOREHUB SYNC STATUS ───────────────────────────────────

model StorehubSync {
  id          String       @id @default(uuid())
  outletId    String
  outlet      Outlet       @relation(fields: [outletId], references: [id])
  syncType    SyncType
  status      SyncStatus   @default(SUCCESS)
  lastSyncAt  DateTime     @default(now())
  recordCount Int          @default(0)
  errorMessage String?
  createdAt   DateTime     @default(now())

  @@index([outletId, syncType, lastSyncAt])
}

enum SyncType {
  PRODUCTS
  SALES
  EMPLOYEES
}

enum SyncStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
}

// ─── APPROVAL RULES ────────────────────────────────────────

model ApprovalRule {
  id          String             @id @default(uuid())
  name        String
  ruleType    ApprovalRuleType
  condition   String
  threshold   Decimal?
  outlets     String[]           @default([])
  approverIds String[]           @default([])
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum ApprovalRuleType {
  ORDER_APPROVAL
  STOCK_ADJUSTMENT
  STOCK_TRANSFER
  CREDIT_NOTE
}

// ─── ACTIVITY LOG ───────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  module     String
  details    String?
  targetId   String?
  targetName String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([module, createdAt])
}

// ─── SOPs (Standard Operating Procedures) ──────────────────

model SopCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sops Sop[]
}

model Sop {
  id          String      @id @default(uuid())
  title       String
  description String?
  categoryId  String
  category    SopCategory @relation(fields: [categoryId], references: [id])
  content     String?
  status      SopStatus   @default(DRAFT)
  sortOrder   Int         @default(0)
  version     Int         @default(1)
  createdById String
  createdBy   User        @relation("SopCreatedBy", fields: [createdById], references: [id])
  publishedAt DateTime?
  // Expected frequency — for compliance gap detection
  expectedRecurrence  ScheduleRecurrence @default(SHIFT)
  expectedTimesPerDay Int                @default(1)   // how many times per day
  expectedTimes       String[]           @default([])  // ["08:00","12:00","16:00"]
  expectedDueMinutes  Int                @default(0)   // 0 = no deadline
  expectedDaysOfWeek  Int[]             @default([])  // empty = every day, [1]=Mon...[7]=Sun
  appliesToAllOutlets Boolean            @default(true) // should be at every outlet?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  steps      SopStep[]
  sopOutlets SopOutlet[]
  checklists Checklist[]
  schedules  SopSchedule[]

  @@index([categoryId])
  @@index([status])
}

enum SopStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model SopStep {
  id            String  @id @default(uuid())
  sopId         String
  sop           Sop     @relation(fields: [sopId], references: [id], onDelete: Cascade)
  stepNumber    Int
  title         String
  description   String?
  imageUrl      String?
  photoRequired Boolean @default(false)

  @@unique([sopId, stepNumber])
  @@index([sopId])
}

model SopOutlet {
  id         String   @id @default(uuid())
  sopId      String
  sop        Sop      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  outletId   String
  outlet     Outlet   @relation(fields: [outletId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([sopId, outletId])
  @@index([outletId])
}

// ─── CHECKLISTS (Daily SOP Instances) ──────────────────────

model Checklist {
  id            String          @id @default(uuid())
  sopId         String
  sop           Sop             @relation(fields: [sopId], references: [id])
  outletId      String
  outlet        Outlet          @relation(fields: [outletId], references: [id])
  assignedToId  String?
  assignedTo    User?           @relation("ChecklistAssignedTo", fields: [assignedToId], references: [id])
  date          DateTime        @db.Date
  shift         Shift           @default(OPENING)
  timeSlot      String?                        // "08:00", "14:00" etc — null for shift-only
  dueAt         DateTime?                      // exact due time for this instance
  status        ChecklistStatus @default(PENDING)
  completedById String?
  completedBy   User?           @relation("ChecklistCompletedBy", fields: [completedById], references: [id])
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items ChecklistItem[]

  @@unique([sopId, outletId, date, shift, assignedToId, timeSlot])
  @@index([outletId, date])
  @@index([assignedToId, date])
  @@index([status])
}

enum Shift {
  OPENING
  MIDDAY
  CLOSING
}

enum ChecklistStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model ChecklistItem {
  id            String     @id @default(uuid())
  checklistId   String
  checklist     Checklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  stepNumber    Int
  title         String
  description   String?
  photoRequired Boolean    @default(false)
  isCompleted   Boolean    @default(false)
  completedById String?
  completedBy   User?      @relation("ChecklistItemCompletedBy", fields: [completedById], references: [id])
  completedAt   DateTime?
  notes         String?
  photoUrl      String?

  @@index([checklistId])
}

// ─── SOP SCHEDULES (Recurring Assignments) ─────────────────

model SopSchedule {
  id           String         @id @default(uuid())
  sopId        String
  sop          Sop            @relation(fields: [sopId], references: [id], onDelete: Cascade)
  outletId     String
  outlet       Outlet         @relation(fields: [outletId], references: [id])
  assignedToId String
  assignedTo   User           @relation("ScheduleAssignedTo", fields: [assignedToId], references: [id])
  shift        Shift          @default(OPENING)
  recurrence   ScheduleRecurrence @default(SHIFT)
  times        String[]       @default([])    // ["08:00","12:00","16:00"]
  dueMinutes   Int            @default(0)     // 0 = no deadline, 30 = must complete within 30min
  daysOfWeek   Int[]          @default([1, 2, 3, 4, 5, 6, 7]) // 1=Mon, 7=Sun
  isActive     Boolean        @default(true)
  startDate    DateTime?      @db.Date
  endDate      DateTime?      @db.Date
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([sopId, outletId, assignedToId, shift])
  @@index([outletId])
  @@index([assignedToId])
}

enum ScheduleRecurrence {
  SHIFT           // Once per shift (current behavior)
  SPECIFIC_TIMES  // At specific times: ["08:00","12:00","16:00"]
  HOURLY          // Every hour during operating hours
}

// ─── REVIEWS ───────────────────────────────────────────────

model ReviewSettings {
  id              String  @id @default(uuid())
  outletId        String  @unique
  outlet          Outlet  @relation(fields: [outletId], references: [id])
  // Google Business Profile
  gbpPlaceId      String?
  gbpAccountId    String?
  gbpLocationName String?
  googleReviewUrl String?
  // QR rating gate
  ratingThreshold Int     @default(4) // >= this → redirect to Google
  // Review page branding
  heading         String?
  description     String?
  logoUrl         String?
  // Feedback form fields config (JSON array of {question, type, required, active})
  feedbackFields  Json?   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InternalFeedback {
  id        String   @id @default(uuid())
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  rating    Int      // 1-5
  name      String?
  phone     String?
  feedback  String?
  source    String   @default("qr") // "qr" | "manual"
  createdAt DateTime @default(now())

  @@index([outletId, createdAt])
}
