{
  "name": "celsius-ops",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:inventory": "cd apps/inventory && npm run dev",
    "dev:loyalty": "cd apps/loyalty && npm run dev",
    "dev:pickup": "cd apps/pickup && npm run dev",
    "db:generate": "cd packages/db && npx prisma generate",
    "db:push": "cd packages/db && npx prisma db push",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:seed": "cd packages/db && npx tsx seed.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
