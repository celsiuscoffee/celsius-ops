{
  "name": "celsius-ops",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:inventory": "cd apps/inventory && npm run dev",
    "dev:loyalty": "cd apps/loyalty && npm run dev",
    "dev:backoffice": "cd apps/backoffice && npm run dev",
    "dev:pos": "cd apps/pos && npm run dev",
    "db:generate": "cd packages/db && npx prisma generate",
    "db:push": "cd packages/db && npx prisma db push",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:seed": "cd packages/db && npx tsx seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/db packages/auth packages/shared"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
