NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Loyalty promotion engine. LOYALTY_BASE_URL is used to evaluate auto-promotions
# and to record applied promos to the ledger at checkout. CRON_SECRET is the
# shared server-to-server secret the engine's /api/promotions/apply requires —
# WITHOUT IT, POS promo usage-limits (per-customer / total) are NOT enforced
# (the apply call is skipped). Must match the loyalty + pickup deployments.
LOYALTY_BASE_URL=https://loyalty.celsiuscoffee.com
CRON_SECRET=your-shared-cron-secret
