{
  "cli": {
    "version": ">= 17.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "channel": "preview"
    },
    "internal": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "channel": "production"
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType":  "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track":         "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleTeamId":   "9U2R774T9W"
      }
    }
  }
}
