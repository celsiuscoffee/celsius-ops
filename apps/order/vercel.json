{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "npx turbo-ignore @celsius-ops/order",
  "crons": [
    { "path": "/api/cron/birthday-treats",                    "schedule": "30 0 * * *" },
    { "path": "/api/cron/loyalty-pushes?job=birthday",        "schedule": "0 1 * * *" },
    { "path": "/api/cron/loyalty-pushes?job=reward-expiring", "schedule": "30 1 * * *" },
    { "path": "/api/cron/loyalty-pushes?job=tier-at-risk",    "schedule": "0 2 * * *" },
    { "path": "/api/cron/voucher-expiring",                   "schedule": "0 2 * * *" },
    { "path": "/api/cron/loyalty-pushes?job=sitting-on-beans","schedule": "0 3 * * *" },
    { "path": "/api/cron/loyalty-pushes?job=custom",          "schedule": "30 3 * * *" },
    { "path": "/api/cron/loyalty-pushes?job=miss-you",        "schedule": "0 3 * * 1" },
    { "path": "/api/cron/streak-update",                      "schedule": "0 4 * * 1" },
    { "path": "/api/cron/auto-hours",                         "schedule": "*/10 * * * *" },
    { "path": "/api/cron/reconcile-pending",                  "schedule": "*/1 * * * *" },
    { "path": "/api/cron/expire-orders",                      "schedule": "*/15 * * * *" },
    { "path": "/api/cron/promote-scheduled",                  "schedule": "*/2 * * * *" },
    { "path": "/api/cron/sync-rm-payouts",                    "schedule": "0 21 * * *" }
  ]
}
